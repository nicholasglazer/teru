#!/bin/bash
# startt — the `startx` of teruwm (start-teru).
#
# Builds the latest release teru + teruwm from source (`make install-local`)
# and installs both to ~/.local/bin, then execs teruwm. Because it rebuilds
# first you can never launch stale code — and unlike xmonad there's no
# separate "recompile" step. A broken build aborts BEFORE the exec (set -e),
# dropping you back to the login shell with the error visible.
#
# Install (symlink so the launcher tracks the repo):
#   ln -sf "$PWD/pkg/startt" ~/.local/bin/startt
# Usage:    startt            # release rebuild + install + launch (default)
#           startt dev         # fast DEBUG rebuild + install + launch
#           startt skip        # skip the rebuild, launch the installed binary
#
# Source-tree location: set TERU_SRC, else the first of these that exists is used.
set -euo pipefail

find_src() {
    if [ -n "${TERU_SRC:-}" ] && [ -f "$TERU_SRC/build.zig" ]; then
        echo "$TERU_SRC"; return 0
    fi
    for d in \
        "$HOME/code/workbench/foss/teru" \
        "$HOME/code/teru" \
        "$HOME/src/teru" \
        "$HOME/teru"; do
        [ -f "$d/build.zig" ] && { echo "$d"; return 0; }
    done
    return 1
}

# Default is DEBUG — the inner-loop build is ~1.3s incremental (after the
# fix-crt idempotency fix), vs release's slow LLVM re-optimization. Use
# `startt release` when you want the optimized daily-driver binary.
MODE="${1:-dev}"
case "$MODE" in
    dev)     TARGET=dev-install   ;;   # fast DEBUG build (default — dev inner loop)
    release) TARGET=install-local ;;   # optimized binary (~85s cold, smoother to daily-drive)
    skip)    TARGET= ;;                # launch the installed binary as-is
    *) echo "usage: startt [dev|release|skip]" >&2; exit 2 ;;
esac

if [ -n "$TARGET" ]; then
    REPO="$(find_src)" || {
        echo "startt: can't find the teru source tree." >&2
        echo "  Set TERU_SRC=/path/to/teru, or run 'startt skip' to launch the installed binary." >&2
        exit 1
    }
    make -C "$REPO" "$TARGET"
fi

# Keyboard layout for TTY launch (env-inheritance break on bare TTY).
KB_ENV="$HOME/.config/environment.d/10-miozu-keyboard.conf"
[ -f "$KB_ENV" ] && { set -a; . "$KB_ENV"; set +a; }

# Clear stale Wayland locks left by a crashed session.
rm -f "/run/user/$(id -u)/wayland-"*.lock 2>/dev/null || true

# Render on the integrated GPU only (dual-GPU PRIME laptop). The Intel iGPU
# (card1, pci 00:02.0) drives the panel (eDP-1); the NVIDIA dGPU is render-only
# with no display heads. Letting wlroots render on the dGPU keeps the RTX awake
# (battery drain + endless `nvidia-modeset: Correcting number of heads` spam) and
# made the compositor exit when DPMS/idle changed the dGPU power state. Pinning
# the DRM backend to the Intel card renders + scans out on one GPU and lets the
# dGPU sleep. Override (e.g. for an nvidia-routed external monitor) by exporting
# WLR_DRM_DEVICES before startt, or delete this block.
#
# CRITICAL: WLR_DRM_DEVICES is COLON-separated (like $PATH). The stable
# /dev/dri/by-path/pci-0000:00:02.0-card name contains colons (PCI address),
# so handing wlroots the by-path verbatim makes it split on those colons into
# three garbage device paths → "Found 0 GPUs, cannot create backend" → teruwm
# never starts. Resolve the by-path symlink to the colon-free /dev/dri/cardN
# node first, and only export if that node actually exists (otherwise leave
# WLR_DRM_DEVICES unset so wlroots autoselects and the compositor still comes up).
_startt_pinned_gpu=0   # 1 only if WE pinned the GPU below (gates the self-heal)
if [ -z "${WLR_DRM_DEVICES:-}" ]; then
    # `|| true`: under `set -e`, a bare assignment from a failing command
    # substitution aborts the script. readlink -f exits non-zero when
    # /dev/dri/by-path/ itself is absent (e.g. no udev by-path rules) — without
    # `|| true` that would strand us at the TTY here, the very failure this
    # block exists to prevent. The guards below handle the resulting empty value.
    _igpu_card="$(readlink -f /dev/dri/by-path/pci-0000:00:02.0-card 2>/dev/null || true)"
    case "$_igpu_card" in
        *:*) _igpu_card="" ;;  # paranoia: never export a colon-bearing value
    esac
    if [ -n "$_igpu_card" ] && [ -e "$_igpu_card" ]; then
        export WLR_DRM_DEVICES="$_igpu_card"
        _startt_pinned_gpu=1
    fi
fi

# Persist teruwm's stderr so a crash/exit reason survives the TTY scrolling
# away (the compositor logs to stderr; without this a silent exit is a mystery).
TERU_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/teru"
mkdir -p "$TERU_LOG_DIR"
TERU_LOG="$TERU_LOG_DIR/teruwm.log"
printf '\n=== startt %s ===\n' "$(date '+%F %T')" >> "$TERU_LOG"

# Run teruwm. NOT `exec` on purpose: if the compositor fails to acquire the
# DRM seat (e.g. another compositor/Xorg holds it) it exits immediately, and
# `exec` would replace this shell — bouncing you to the login prompt before
# you can read the error. Running it as a child keeps the error on screen and
# drops you back to the shell. Hot-restart ($mod+') is unaffected: teruwm
# re-execs itself in place regardless of its parent.
# `set +e` so a non-zero exit doesn't trip `set -e` before the error help;
# `tee` keeps the error on the TTY AND appends it to the log; PIPESTATUS[0]
# captures teruwm's real exit (not tee's).
_run_teruwm() {
    "$HOME/.local/bin/teruwm" 2>&1 | tee -a "$TERU_LOG"
    return "${PIPESTATUS[0]}"
}

set +e
_run_teruwm
status=$?
# Self-heal: if teruwm failed AND *we* pinned the GPU, the pin is the likeliest
# culprit (bad device node, GPU renamed across reboot, etc). Retry once on the
# default GPU so a GPU-pin mistake can never leave you stranded at the TTY.
# Gated on _startt_pinned_gpu (not just "is WLR_DRM_DEVICES set") so a user's
# deliberate pre-exported override is respected, not silently clobbered — if
# their own pin fails they get the error help + log below to debug it.
if [ "$status" -ne 0 ] && [ "$_startt_pinned_gpu" -eq 1 ]; then
    printf '\n[startt] teruwm exited %d with WLR_DRM_DEVICES=%s — retrying on the default GPU\n' \
        "$status" "$WLR_DRM_DEVICES" | tee -a "$TERU_LOG"
    unset WLR_DRM_DEVICES
    _run_teruwm
    status=$?
fi
set -e
if [ "$status" -ne 0 ]; then
    echo
    echo "── teruwm exited with status $status. Common causes on a bare TTY:"
    echo "   • 'Timeout waiting session to become active' / 'Could not connect"
    echo "     to remote display' → another compositor or Xorg holds the DRM"
    echo "     seat. Quit it, or launch from a VT that owns the active seat."
    echo "   • Run from a graphical session (WAYLAND_DISPLAY/DISPLAY set) →"
    echo "     teruwm is a root compositor; launch it from a bare TTY."
    echo "Press Enter to return to the shell…"; read -r _
fi
